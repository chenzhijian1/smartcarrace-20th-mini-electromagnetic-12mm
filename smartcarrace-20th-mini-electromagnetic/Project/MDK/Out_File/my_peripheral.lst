  801          float StrToDouble(const char *s)
  802          {
  803   1      
  804   1          int i = 0;
  805   1          int k = 0;
  806   1          float j;
  807   1          int flag = 1;
  808   1          float result = 0.0;
  809   1          if (s[i] == '+')
  810   1          {
  811   2              i++;
  812   2          }
  813   1          if (s[i] == '-')
  814   1          {
  815   2              i++;
  816   2              flag = -1;
  817   2          }
  818   1          while (s[i] != '\0' && s[i] != '.')
  819   1          {
  820   2              j = (s[i] - '0') * 1.0;
  821   2              result = result * 10 + j;
  822   2              i++;
  823   2          }
  824   1          if (s[i] == '.')
  825   1          {
  826   2              i++;
  827   2              while (s[i] != '\0' && s[i] != ' ')
  828   2              {
  829   3                  k++;
  830   3                  j = s[i] - '0';
  831   3                  result = result + (1.0 * j) / pow(10.0, k);
  832   3                  i++;
  833   3              }
  834   2          }
  835   1          result = flag * result;
  836   1          return result;
  837   1      }
