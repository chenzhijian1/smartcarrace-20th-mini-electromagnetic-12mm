  138          //-------------------------------------------------------------------------------------------------------
             -------------
  139          void iap_write_bytes(uint32 addr, uint8 *buf, uint16 len)
  140          {
  141   1      
  142   1              IAP_CMD = 2;                            //ЩшжУ IAP ЖСУќСю       
  143   1              
  144   1              while(len--)
  145   1              {
  146   2              IAP_ADDRE = 0;
  147   2                      IAP_ADDRL = addr;               //ЩшжУ IAP ЕЭЕижЗ
  148   2                      IAP_ADDRH = addr >> 8;  //ЩшжУ IAP ИпЕижЗ
  149   2                      IAP_ADDRE = addr >> 16; //ЩшжУ IAP зюИпЕижЗ
  150   2                      IAP_DATA = *buf++;              //аД IAP Ъ§Он
  151   2                      addr++;
  152   2      
  153   2                      eeprom_trig();
  154   2              }
  155   1              
  156   1      }
