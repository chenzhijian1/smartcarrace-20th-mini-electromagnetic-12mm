  109          void iap_read_bytes(uint32 addr, uint8 *buf, uint16 len)
  110          {
  111   1      
  112   1              
  113   1              IAP_CMD = 1;                            //ЩшжУ IAP ЖСУќСю       
  114   1      
  115   1              while(len--)
  116   1              {
  117   2              IAP_ADDRE = 0;
  118   2                      IAP_ADDRL = addr;               //ЩшжУ IAP ЕЭЕижЗ
  119   2                      IAP_ADDRH = addr >> 8;  //ЩшжУ IAP ИпЕижЗ
  120   2                      IAP_ADDRE = addr >> 16; //ЩшжУ IAP зюИпЕижЗ
  121   2              eeprom_trig();
  122   2                      *buf++ = IAP_DATA;              //ЖС IAP Ъ§Он
  123   2                      addr++;
  124   2                      
  125   2              }
  126   1              
  127   1      }
