  191          void extern_iap_write_bytes(uint16 addr, uint8 *buf, uint16 len)
  192          { 
  193   1              uint8 temp[512];
  194   1              uint16 i;
  195   1              
  196   1              for(i=0; i<512 ;i++)    temp[i] = 0;                    //Чх0
  197   1              iap_read_bytes(addr&0xFE00, temp, 512);                 //ЖСШЁ
  198   1              for(i=0; i<len; i++)    temp[(addr&0x1FF) + i] = buf[i];        //ИФ
  199   1              iap_erase_page(addr);                                                   //ВСГ§
  200   1              iap_write_bytes(addr&0xFE00, temp, 512);                //аДШы
  201   1      }
